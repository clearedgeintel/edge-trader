# Alpaca API (paper trading by default)
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_PAPER=true

# Risk overrides (optional — defaults are small-account safe)
# RISK_PER_TRADE_PCT=0.005
# MAX_PORTFOLIO_HEAT_PCT=0.025
# MAX_CONCURRENT_POSITIONS=3
# ATR_MULTIPLIER=1.8
# MIN_REWARD_RISK=2.5
# DAILY_LOSS_LIMIT_PCT=0.02
# MAX_DRAWDOWN_PAUSE_PCT=0.10

# Strategy
# MIN_CONFLUENCE_SCORE=70

# Supabase persistence (optional). When both are set, open positions, closed
# trades, signals, report cards, and engine state (peak equity + daily P&L) are
# persisted and rehydrated on restart. Unset = in-memory only. Server-side
# service-role key — never expose client-side.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your_service_key

# Execution (disabled by default — must opt-in)
EXECUTION_ENABLED=false

# Broker-resident protective stops (default true). When enabled, whole-share
# positions get a resting GTC stop order at Alpaca that survives restarts and
# between-scan gaps. Fractional positions cannot rest stops at Alpaca and fall
# back to monitor-poll exits. Set false to manage all stops via polling.
# BROKER_STOPS=true

# Ramp phases: observation | paper | live_ramp | live_full
# EXECUTION_ENABLED=true auto-sets paper if RAMP_MODE not specified
RAMP_MODE=observation

# Live trading (requires ALPACA_PAPER=false + ramp live_ramp or live_full)
LIVE_ENABLED=false

# Emergency halt — blocks all order placement immediately
KILL_SWITCH=false

# Report Cards (template by default; LLM optional)
REPORT_CARDS_LLM_ENABLED=false
# ANTHROPIC_API_KEY=your_key_here

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development